# ---- Application ----
APP_NAME=AI CCTV Attendance
DATABASE_URL=sqlite:///./data/attendance.db

# ---- Camera ----
# RTSP CCTV stream, e.g. rtsp://user:pass@192.168.1.10:554/Streaming/Channels/101
# Use "0" to fall back to the local webcam for development.
RTSP_URL=0
CAMERA_ID=CAM-1

# ---- Face recognition (OpenCV YuNet detector + SFace recognizer) ----
# Cosine-similarity threshold for a positive match (0-1). SFace's recommended
# operating point is ~0.363. Raise to reduce false matches.
RECOGNITION_THRESHOLD=0.363
# Minimum YuNet detection confidence to consider a face at all (0-1).
MIN_FACE_SCORE=0.7

# ---- Attendance rules ----
# Office start time (HH:MM). Arrivals after WORK_START + GRACE_MINUTES are flagged "late".
WORK_START=09:00
GRACE_MINUTES=10
# Minimum seconds before the same person is logged again (debounce).
RECOGNITION_COOLDOWN_SECONDS=60
